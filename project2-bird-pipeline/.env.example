# Copy to .env and fill in to override the local Docker defaults.

# --- Local Docker (defaults, used if .env is absent) ---
MONGO_URI=mongodb://bird:bird_dev_pw@localhost:27017/?authSource=admin
MONGO_DB=birds
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=birdminio
MINIO_SECRET_KEY=birdminio_dev_pw
MINIO_SECURE=false
AUDIO_BUCKET=bird-audio
LOG_BUCKET=classify-logs
AVES_BASE=https://aves.regoch.net
AUDIO_DIR=audio
OUTPUT_DIR=output
DEFAULT_LAT=45.8150
DEFAULT_LON=15.9819

# --- Cloud: MongoDB Atlas (uncomment + fill to use instead of Docker Mongo) ---
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
